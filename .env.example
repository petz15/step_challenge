# Copy this file to .env and fill in your values.
# docker-compose reads this automatically.

# PostgreSQL connection — use host.docker.internal to reach the host machine's Postgres.
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=step_challenge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword

# Change this to a long random string before sharing the app with anyone.
JWT_SECRET=change-me-to-a-long-random-string
