# Copy to .env and fill in your values.

# PostgreSQL — use host.docker.internal to reach the host machine's Postgres from inside Docker.
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=step_challenge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword

# Change to a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# LAN IP of this machine for phone/tablet access on the same network.
# Find it with: ip a
# Leave unset to default to localhost.
# DEV_MACHINE_IP=192.168.1.x
