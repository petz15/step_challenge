# Copy this file to .env and fill in your values.
# docker-compose reads this automatically.

# Point to the host machine's PostgreSQL.
# Use host.docker.internal as the hostname — docker-compose.yml maps it to the host.
DATABASE_URL=postgresql+psycopg://postgres:yourpassword@host.docker.internal:5432/step_challenge

# Change this to a long random string before sharing the app with anyone.
JWT_SECRET=change-me-to-a-long-random-string
